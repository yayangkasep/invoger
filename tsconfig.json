{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts", "src/components/outlet-table.tsx.bak", "src/lib/.firebase.ts", "src/lib/.firebaseAdmin.ts", "src/components/products-page.tsx.bak", "src/components/products-table.tsx.bak", "src/components/theme-selector.tsx.bak", "src/components/theme-provider.tsx.bak", "src/components/togel-dark-mode.tsx.bak", "src/components/tables/invoice-table copy.tsx.bak", "src/components/active-theme.tsx.bak"],
  "exclude": ["node_modules"]
}
